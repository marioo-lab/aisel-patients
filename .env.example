# Aisel Patients — environment. Copy to .env and fill in.

# Neon Postgres connection string (include ?sslmode=require).
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/aisel?sslmode=require"

# JWT signing secret (HS256). Generate one: `openssl rand -hex 32`
AUTH_SECRET="change-me-to-a-long-random-hex-string"
